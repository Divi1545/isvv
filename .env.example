# ============================================================
# IslandLoaf Vendor Platform — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── NODE ─────────────────────────────────────────────────────
NODE_ENV=production

# ── DATABASE (REQUIRED) ──────────────────────────────────────
# Use ONE of:
#   SUPABASE_DB_URL  → Supabase PostgreSQL connection string
#   DATABASE_URL     → Any PostgreSQL connection string (Railway Postgres, etc.)
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
SUPABASE_DB_URL=
DATABASE_URL=

# ── SUPABASE API (required for image uploads & auth features) ─
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── SESSION (REQUIRED) ───────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# ── ADMIN CREDENTIALS (REQUIRED) ────────────────────────────
# Fallback credentials when no users exist in the database
ADMIN_EMAIL=admin@islandloaf.com
ADMIN_PASSWORD=

# ── OPENAI (required for AI agents & chatbot) ────────────────
OPENAI_API_KEY=

# ── STRIPE (required for payments & vendor payouts) ──────────
# Found in: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── TELEGRAM BOT (optional — enables Telegram lead intake) ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
ADMIN_TELEGRAM_CHAT_ID=

# ── AGENT SYSTEM (optional) ──────────────────────────────────
# Set to "true" to enable background AI agent task runner
AGENT_RUNNER_ENABLED=false
# API key for agent-to-agent communication
AGENT_API_KEY=
# Owner agent key (highest privilege)
OWNER_AGENT_KEY=

# ── MISC (optional) ──────────────────────────────────────────
# Public URL of this deployment (used in emails, webhooks)
APP_URL=https://your-app.railway.app
# Set to "true" to force in-memory storage (no DB, dev only)
FORCE_MEMORY_STORAGE=false
# Require admin approval before new vendors can log in
REQUIRE_OWNER_APPROVAL=false
# Disable SSL for local Postgres (set to "disable" if using Railway Postgres without SSL)
# PGSSLMODE=disable
