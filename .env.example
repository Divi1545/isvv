# === Database (Required) ===
# Direct Supabase connection (preferred)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Supabase pooler connection (optional, used if set — overrides DATABASE_URL)
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# SUPABASE_DB_URL=

# === Supabase REST API (Required for non-auth operations) ===
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# === Session (Required for production) ===
SESSION_SECRET=generate-a-random-string-here

# === Server ===
NODE_ENV=development
PORT=5000

# === Stripe (Optional) ===
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=

# === AI (Optional) ===
# ANTHROPIC_API_KEY=

# === Agent Runner (Optional) ===
# AGENT_RUNNER_ENABLED=true
